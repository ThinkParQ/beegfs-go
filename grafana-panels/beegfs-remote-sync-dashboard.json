        "id": 1,
        "type": "stat",
        "title": "Failed jobs (last 15m)",
        "description": "Count of jobs that reached the `failed` terminal state in the last 15m, summed across all RSTs selected by $rst_id. Drill into panel 6 + 7 to identify which RST.",
