      {
        "id": 6,
        "type": "timeseries",
        "title": "Failures over time per RST",
        "description": "Per-RST stacked rate of `failed|cancelled|unknown` terminal states (5m window). Lines stack so total height = total bad-outcome rate. Empty band = all RSTs healthy.",
        "datasource": {
          "type": "prometheus",
          "uid": "cfh9rfys1kd1cd"
        },
        "gridPos": {
          "x": 0,
          "y": 11,
          "w": 12,
          "h": 8
        },
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom",
            "showLegend": true
          },
          "tooltip": {
            "mode": "multi",
            "sort": "desc"
          }
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "fillOpacity": 20,
              "showPoints": "never",
              "stacking": {
                "mode": "normal",
                "group": "A"
              }
            },
            "unit": "ops"
          },
          "overrides": []
        },
        "targets": [
          {
            "refId": "A",
            "expr": "sum by (rst_id, state)(rate(remote_job_terminal_total{state=~\"failed|cancelled|unknown\", rst_id!=\"0\", rst_id=~\"$rst_id\"}[5m]))",
            "legendFormat": "{{rst_id}} / {{state}}",
            "editorMode": "code",
            "range": true,
            "instant": false,
            "datasource": {
              "type": "prometheus",
              "uid": "cfh9rfys1kd1cd"
            }
          }
        ],
        "pluginVersion": "12.4.2"
      },
