            }
          }
        ],
        "pluginVersion": "12.4.2"
      },
      {
        "id": 5,
        "type": "stat",
        "title": "Net arrivals (in \u2212 out, 5m)",
        "description": "Net job arrivals in last 5m: `requests - terminal`. A growing positive value means jobs are coming in faster than they finish \u2014 backlog forming. Negative is clamped to 0. NOT a live 'active jobs' count.",
        "datasource": {
          "type": "prometheus",
          "uid": "cfh9rfys1kd1cd"
        },
        "gridPos": {
          "x": 20,
          "y": 6,
          "w": 4,
          "h": 4
        },
        "options": {
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ],
            "fields": "",
            "values": false
          },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "decimals": 0
          },
          "overrides": []
        },
        "targets": [
          {
            "refId": "A",
            "expr": "clamp_min(sum(increase(remote_job_requests_total[5m])) - sum(increase(remote_job_terminal_total[5m])), 0)",
            "legendFormat": "net",
            "editorMode": "code",
            "range": false,
            "instant": true,
            "datasource": {
              "type": "prometheus",
              "uid": "cfh9rfys1kd1cd"
            }
          }
        ],
        "pluginVersion": "12.4.2"
      },
      {
        "id": 1001,
        "type": "row",
        "title": "Per-RST troubleshooting",
