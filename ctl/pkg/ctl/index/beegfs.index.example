# .beegfs.index — place at the BeeGFS mount root (e.g. /mnt/beegfs/.beegfs.index)
#
# Each [[index]] entry maps a subtree to its GUFI index location.
# The entry with the longest matching "path" prefix wins.

# Index the entire filesystem locally
[[index]]
path = "/"
root = "/mnt/index"
addr = "local"

# # Example: index a subtree on a remote server
# [[index]]
# path = "/project-b"
# root = "/mnt/remote-index"
# addr = "ssh:indexserver.cluster.local"
